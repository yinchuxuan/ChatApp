[{"id":"wa2-tail-timeline-guide",
  "when":{"phase":"pre_send"},
  "then":[
    {"type":"exec","sourceFile":"scripts/timeline.js"},
    {"type":"replace",
     "predicate":{"role":"user","index":"last"},
     "content":{
        "prefix":"{{original_content}} + {{raw_string:\n\n---\n<wa2_turn_context>\n请结合以上行动和以下剧情引导生成剧情:\n}}",
        "include":[
            {"when":{"state":{"temp.includeFreeGuide":true}},"content":"{{file:plot_guides#剧情大纲}}"},
            {"when":{"state":{"temp.PlotType":{"exists":true}}},"content":"{{file:plot_guides#$temp.PlotType}}"},
            {"when":{"state":{"temp.plotKind":"free"}},"content":"{{file:plot_guides#$temp.plotMoodSection}}"},
            {"when":{"state":{"temp.plotKind":"free"}},"content":"{{file:plot_guides#$temp.toumaAttitudeSection}}"},
            {"when":{"state":{"temp.plotKind":"free"}},"content":"{{file:plot_guides#$temp.setsunaAttitudeSection}}"},
            {"when":{"state":{"temp.includeFreeGuide":true}},"content":"{{file:plot_guides#剧情限制}}"}
        ],
        "suffix":"{{raw_string:\n\n}} + {{file:roleplay_rules}} + {{raw_string:\n</wa2_turn_context>}}"
     }
    }
    ]
}]
