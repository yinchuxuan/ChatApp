{
  "version": "1.0",
  "id": "white-album-2",
  "name": "白色相簿2",
  "rules": [
    {
      "id": "wa2-system-prompt",
      "when": {
        "phase": "pre_send",
        "length": { "eq": 1 }
      },
      "then": [
        {
          "type": "insert",
          "predicate": { "all": true },
          "role": "system",
          "content": "现在开始白色相簿2 roleplay，用户扮演北原春希",
          "anchor": "before",
          "_meta": { "source": "wa2_system_prompt", "visibility": "llm_only" }
        },
        {
          "type": "insert",
          "predicate": { "_meta.source": "wa2_system_prompt" },
          "role": "assistant",
          "content": "历史对话总结:\n暂无",
          "anchor": "after",
          "_meta": { "source": "wa2_summary", "visibility": "user_visible" }
        }
      ]
    },
    {
      "id": "wa2-compress-assistant-history",
      "when": {
        "phase": "pre_send",
        "any": {
          "role": "assistant",
          "content": { "regex": "<summary>[\\s\\S]*?</summary>" }
        }
      },
      "then": [
        {
          "type": "replace",
          "predicate": { "_meta.source": "wa2_summary" },
          "find": {
            "summaryMsgs": {
              "predicate": {
                "role": "assistant",
                "content": { "regex": "<summary>[\\s\\S]*?</summary>" }
              }
            }
          },
          "content": "{{original_content}}.regex_replace{pattern:'\\n暂无\\s*$',with:''} + {{raw_string:\n}} + {{find:summaryMsgs}}.regex_extract{pattern:'<summary>([\\s\\S]*?)</summary>'}.format{'- {{value}}'}.join{'\\n'}"
        },
        {
          "type": "remove",
          "predicate": {
            "role": "assistant",
            "content": { "regex": "<summary>[\\s\\S]*?</summary>" }
          }
        }
      ]
    },
    {
      "id": "wa2-keep-latest-user",
      "when": {
        "phase": "pre_send"
      },
      "then": [
        {
          "type": "remove",
          "predicate": {
            "role": "user",
            "not": { "index": "last" }
          }
        }
      ]
    },
    {
      "id": "wa2-tail-system-hint",
      "when": {
        "phase": "pre_send"
      },
      "then": [
        {
          "type": "insert",
          "predicate": { "index": "last" },
          "anchor": "after",
          "role": "system",
          "content": "roleplay规则:\n 1.剧情符合白色相簿2设定，用户扮演北原春希\n 2.剧情要体现青春爱情的美好以及三人关系纠缠的纠结\n 3.每段剧情不少于1000字 \n 4.在每段剧情的末尾给出ABCD四个选项给用户提供下一步行动的选择\n 5.每条回复最后必须追加 <summary>...</summary>，其中只写本条回复的简短剧情总结",
          "ttl": 1,
          "_meta": { "source": "wa2_tail_hint", "visibility": "llm_only" }
        }
      ]
    }
  ]
}
