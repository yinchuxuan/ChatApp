[
    {"id":"wa2-compress-assistant-history",
     "when":{
        "phase":"pre_send",
        "any":{"role":"assistant",
               "content":{"regex":"<summary>[\\s\\S]*?</summary>"},
               "exec":"return i !== msgs.reduce((last, msg, index) => msg.role === 'assistant' ? index : last, -1);"}
            },
     "then":[
        {"type":"replace",
         "predicate":{"_meta.source":"wa2_summary"},
         "find":[
            {"name":"summaryMsgs",
             "from":{"role":"assistant",
                     "content":{"regex":"<summary>[\\s\\S]*?</summary>"},
                     "exec":"return i !== msgs.reduce((last, msg, index) => msg.role === 'assistant' ? index : last, -1);"},
                     "match":{"regex":"<summary>([\\s\\S]*?)</summary>","group":1},
                     "many":true
            }
         ],
         "content":"{{original_content}}.regex_replace{pattern:'\\n暂无\\s*$',with:''} + {{raw_string:\n}} + {{state:temp.find.summaryMsgs}}.format{'- {{value}}'}.join{'\\n'}"},
        {"type":"remove",
         "predicate":{"role":"assistant",
                      "content":{"regex":"<summary>[\\s\\S]*?</summary>"},
                      "exec":"return i !== msgs.reduce((last, msg, index) => msg.role === 'assistant' ? index : last, -1);"}
                     }
     ]
    },
    {"id":"wa2-keep-latest-user",
     "when":{"phase":"pre_send"},
     "then":[
        {"type":"remove",
         "predicate":{"role":"user","not":{"index":"last"}}
        }
     ]
    }
]
