{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chatapp.local/schemas/game-card.schema.json",
  "title": "Game Card",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "id", "name", "rules"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "state": { "type": "object" },
    "audio": { "$ref": "#/definitions/audio" }, "visual": { "$ref": "#/definitions/visual" },
    "rules": { "type": "array", "items": { "$ref": "#/definitions/rule" } },
    "display": { "$ref": "#/definitions/display" }
  },
  "definitions": {
    "audio": { "type": "object", "additionalProperties": false, "properties": { "bgm": { "$ref": "#/definitions/audioMap" } } },
    "audioMap": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+\\.(mp3|ogg|wav|m4a)$" } },
    "visual": { "type": "object", "additionalProperties": false, "properties": { "stylesheet": { "type": "string", "pattern": "^(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+\\.css$" }, "background": { "$ref": "#/definitions/imageMap" } } },
    "imageMap": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+\\.(png|jpg|jpeg|webp|gif|bmp)$" } },
    "display": { "type": "object", "additionalProperties": false, "properties": { "stylesheet": { "type": "string", "pattern": "^[^/\\\\][^\\\\]*$" }, "assistant": { "type": "array", "items": { "$ref": "#/definitions/displayRule" } } } },
    "displayRule": { "type": "object", "additionalProperties": false, "required": ["stage", "type", "pattern"], "properties": { "id": { "type": "string", "minLength": 1 }, "enabled": { "type": "boolean" }, "stage": { "const": "before_markdown" }, "type": { "const": "regex_replace" }, "pattern": { "type": "string", "maxLength": 1000 }, "flags": { "type": "string", "pattern": "^[gimsu]*$" }, "replace": { "type": "string" } } },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["when", "then"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "when": { "$ref": "#/definitions/when" },
        "find": { "$ref": "#/definitions/find" },
        "then": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/action" } }
      }
    },
    "when": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase"],
      "properties": {
        "phase": { "enum": ["init", "pre_send", "after_response"] },
        "length": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "$ref": "#/definitions/comparison" }] },
        "last": { "$ref": "#/definitions/lastPredicate" },
        "any": { "$ref": "#/definitions/predicate" },
        "all": { "$ref": "#/definitions/predicate" },
        "state": { "$ref": "#/definitions/statePredicate" }
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "gt": { "type": "integer", "minimum": 0 },
        "gte": { "type": "integer", "minimum": 0 },
        "lt": { "type": "integer", "minimum": 0 },
        "lte": { "type": "integer", "minimum": 0 },
        "eq": { "type": "integer", "minimum": 0 }
      }
    },
    "action": {
      "oneOf": [
        { "$ref": "#/definitions/insertAction" },
        { "$ref": "#/definitions/removeAction" },
        { "$ref": "#/definitions/replaceAction" },
        { "$ref": "#/definitions/execAction" },
        { "$ref": "#/definitions/stateValueAction" },
        { "$ref": "#/definitions/stateDeleteAction" },
        { "$ref": "#/definitions/stateRollAction" },
        { "$ref": "#/definitions/stateRandomIntAction" }
      ]
    },
    "insertAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "role", "content"],
      "properties": {
        "type": { "const": "insert" },
        "when": { "$ref": "#/definitions/contentWhen" },
        "predicate": { "$ref": "#/definitions/predicate" },
        "anchor": { "enum": ["before", "after"] },
        "role": { "$ref": "#/definitions/messageRole" },
        "content": { "$ref": "#/definitions/content" },
        "find": { "$ref": "#/definitions/find" },
        "ttl": { "$ref": "#/definitions/ttl" },
        "_meta": { "$ref": "#/definitions/messageMeta" }
      }
    },
    "removeAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "predicate"],
      "properties": {
        "type": { "const": "remove" },
        "when": { "$ref": "#/definitions/contentWhen" },
        "predicate": { "$ref": "#/definitions/predicate" }
      }
    },
    "replaceAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "predicate"],
      "anyOf": [{ "required": ["content"] }, { "required": ["ttl"] }],
      "properties": {
        "type": { "const": "replace" },
        "when": { "$ref": "#/definitions/contentWhen" },
        "predicate": { "$ref": "#/definitions/predicate" },
        "content": { "$ref": "#/definitions/content" },
        "find": { "$ref": "#/definitions/find" },
        "ttl": { "$ref": "#/definitions/ttl" },
        "_meta": { "$ref": "#/definitions/messageMeta" }
      }
    },
    "execAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "source"],
      "properties": {
        "type": { "const": "exec" },
        "when": { "$ref": "#/definitions/contentWhen" },
        "source": { "type": "string", "minLength": 1 }
      }
    },
    "statePath": { "type": "string", "pattern": "^[^.[\\]]+(\\.[^.[\\]]+)*$" },
    "jsonValue": { "anyOf": [{ "type": ["string", "number", "boolean", "null"] }, { "type": "array", "items": { "$ref": "#/definitions/jsonValue" } }, { "type": "object", "additionalProperties": { "$ref": "#/definitions/jsonValue" } }] },
    "stateValueAction": { "type": "object", "additionalProperties": false, "required": ["type", "path", "value"], "properties": { "type": { "enum": ["state.set", "state.append", "state.remove"] }, "when": { "$ref": "#/definitions/contentWhen" }, "path": { "$ref": "#/definitions/statePath" }, "value": { "$ref": "#/definitions/jsonValue" } } },
    "stateDeleteAction": { "type": "object", "additionalProperties": false, "required": ["type", "path"], "properties": { "type": { "enum": ["state.delete", "state.advance"] }, "when": { "$ref": "#/definitions/contentWhen" }, "path": { "$ref": "#/definitions/statePath" } } },
    "stateRollAction": { "type": "object", "additionalProperties": false, "required": ["type", "path", "dice"], "properties": { "type": { "const": "state.roll" }, "when": { "$ref": "#/definitions/contentWhen" }, "path": { "$ref": "#/definitions/statePath" }, "dice": { "type": "string", "pattern": "^([1-9]\\d*)?d([1-9]\\d*)$" } } },
    "stateRandomIntAction": { "type": "object", "additionalProperties": false, "required": ["type", "path", "min", "max"], "properties": { "type": { "const": "state.randomInt" }, "when": { "$ref": "#/definitions/contentWhen" }, "path": { "$ref": "#/definitions/statePath" }, "min": { "type": "integer" }, "max": { "type": "integer" } } },
    "find": { "anyOf": [{ "$ref": "#/definitions/findMap" }, { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/findItem" } }] },
    "findMap": { "type": "object", "additionalProperties": { "$ref": "#/definitions/findSpec" }, "minProperties": 1 },
    "findSpec": { "type": "object", "additionalProperties": false, "required": ["predicate"], "properties": { "predicate": { "$ref": "#/definitions/predicate" }, "join": { "type": "string" } } },
    "findItem": { "type": "object", "additionalProperties": false, "required": ["name", "from"], "properties": { "name": { "type": "string", "minLength": 1 }, "from": { "$ref": "#/definitions/predicate" }, "select": { "enum": ["content", "thinking", "role", "_meta.source"] }, "match": { "$ref": "#/definitions/findMatch" }, "many": { "type": "boolean" }, "join": { "type": "string" }, "default": { "$ref": "#/definitions/jsonValue" } } },
    "findMatch": { "type": "object", "additionalProperties": false, "required": ["regex"], "properties": { "regex": { "type": "string", "minLength": 1 }, "group": { "type": "integer", "minimum": 0 } } },
    "predicate": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "role": { "anyOf": [{ "$ref": "#/definitions/messageRole" }, { "$ref": "#/definitions/stringSetMatcher" }] },
        "content": { "anyOf": [{ "type": "string" }, { "$ref": "#/definitions/stringMatcher" }] },
        "thinking": { "$ref": "#/definitions/stringMatcher" },
        "_meta.source": { "anyOf": [{ "type": "string" }, { "$ref": "#/definitions/stringMatcher" }] },
        "index": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "const": "last" }] },
        "all": { "const": true },
        "exec": { "type": "string", "minLength": 1 },
        "or": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/predicate" }
        },
        "not": { "$ref": "#/definitions/predicate" }
      }
    },
    "lastPredicate": {
      "anyOf": [
        { "$ref": "#/definitions/predicate" },
        { "type": "object", "additionalProperties": false, "minProperties": 2, "required": ["num"], "properties": { "num": { "type": "integer", "minimum": 1 }, "role": { "anyOf": [{ "$ref": "#/definitions/messageRole" }, { "$ref": "#/definitions/stringSetMatcher" }] }, "content": { "anyOf": [{ "type": "string" }, { "$ref": "#/definitions/stringMatcher" }] }, "thinking": { "$ref": "#/definitions/stringMatcher" }, "_meta.source": { "anyOf": [{ "type": "string" }, { "$ref": "#/definitions/stringMatcher" }] }, "index": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "const": "last" }] }, "all": { "const": true }, "exec": { "type": "string", "minLength": 1 }, "or": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/predicate" } }, "not": { "$ref": "#/definitions/predicate" } } }
      ]
    },
    "stringMatcher": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "contains": { "type": "string" },
        "regex": { "type": "string", "minLength": 1 },
        "in": { "$ref": "#/definitions/stringList" },
        "nin": { "$ref": "#/definitions/stringList" }
      }
    },
    "stringSetMatcher": { "type": "object", "additionalProperties": false, "minProperties": 1, "properties": { "in": { "$ref": "#/definitions/stringList" }, "nin": { "$ref": "#/definitions/stringList" } } },
    "stringList": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "statePredicate": { "type": "object", "additionalProperties": { "anyOf": [{ "type": ["string", "number", "boolean", "null"] }, { "$ref": "#/definitions/stateMatcher" }] }, "minProperties": 1 },
    "stateMatcher": { "type": "object", "additionalProperties": false, "minProperties": 1, "properties": { "eq": {}, "gt": { "type": ["number", "string"] }, "gte": { "type": ["number", "string"] }, "lt": { "type": ["number", "string"] }, "lte": { "type": ["number", "string"] }, "in": { "type": "array", "minItems": 1 }, "nin": { "type": "array", "minItems": 1 }, "contains": {}, "exists": { "type": "boolean" }, "regex": { "type": "string" } } },
    "content": { "anyOf": [{ "type": "string" }, { "$ref": "#/definitions/contentInclude" }, { "$ref": "#/definitions/contentSelect" }] }, "contentInclude": { "type": "object", "additionalProperties": false, "required": ["include"], "properties": { "include": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/contentBranch" } }, "join": { "type": "string" }, "prefix": { "$ref": "#/definitions/content" }, "suffix": { "$ref": "#/definitions/content" } } }, "contentSelect": { "type": "object", "additionalProperties": false, "required": ["select"], "properties": { "select": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/contentBranch" } }, "default": { "$ref": "#/definitions/content" }, "prefix": { "$ref": "#/definitions/content" }, "suffix": { "$ref": "#/definitions/content" } } }, "contentBranch": { "type": "object", "additionalProperties": false, "required": ["content"], "properties": { "when": { "$ref": "#/definitions/contentWhen" }, "content": { "$ref": "#/definitions/content" } } }, "contentWhen": { "type": "object", "additionalProperties": false, "minProperties": 1, "properties": { "phase": { "enum": ["init", "pre_send", "after_response"] }, "length": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "$ref": "#/definitions/comparison" }] }, "last": { "$ref": "#/definitions/lastPredicate" }, "any": { "$ref": "#/definitions/predicate" }, "all": { "$ref": "#/definitions/predicate" }, "state": { "$ref": "#/definitions/statePredicate" } } },
    "messageRole": { "enum": ["user", "assistant", "system"] },
    "ttl": { "type": "integer", "minimum": -1 },
    "messageMeta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source": { "type": "string" },
        "visibility": { "enum": ["llm_only", "user_visible", "debug_only"] }
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "content"],
      "properties": {
        "role": { "$ref": "#/definitions/messageRole" },
        "content": { "type": "string" },
        "thinking": { "type": "string" },
        "_meta": { "$ref": "#/definitions/messageMeta" },
        "ttl": { "$ref": "#/definitions/ttl" }
      } }
  }
}
