{
  "schema": {
    "touma.affection": {
      "type": "number",
      "default": 0,
      "min": 0,
      "max": 100,
      "onInvalid": "clamp",
      "description": "冬马和纱对玩家/春希当前路线的好感度",
      "llmRead": true,
      "uiVisible": true
    },
    "setsuna.affection": {
      "type": "number",
      "default": 0,
      "min": 0,
      "max": 100,
      "onInvalid": "clamp",
      "description": "小木曾雪菜对玩家/春希当前路线的好感度",
      "llmRead": true,
      "uiVisible": true
    },
    "timeline.currentTime": {
      "type": "string",
      "default": "2007.10.20: 15:00 星期六",
      "description": "当前剧情具体时间点，格式固定为 YYYY.MM.DD: HH:mm 星期X。LLM 每轮用 state.set 写入本轮正文结束时的时间，剧情引导按该时间落入的区间选择。",
      "llmRead": true,
      "llmWrite": true
    },
    "timeline.currentSlot": {
      "type": "string",
      "default": "FreePlot1",
      "description": "当前剧情节点，由 timeline resolver 写入，LLM 只读。",
      "llmRead": true,
      "llmWrite": false
    },
    "timeline.currentSlotEnd": {
      "type": "string",
      "default": "",
      "description": "当前剧情节点允许推进到的最晚时间，由 timeline resolver 写入，LLM 只读。",
      "llmRead": true,
      "llmWrite": false
    },
    "story.chapter": {
      "type": "enum",
      "values": ["chapter_1", "chapter_2"],
      "default": "chapter_1",
      "description": "当前剧情章节。章节 timeline resolver 根据该值选择对应章节的剧情映射。",
      "llmRead": true,
      "llmWrite": true
    },
    "story.route": {
      "type": "enum",
      "values": ["common"],
      "default": "common",
      "description": "当前剧情路线。后续章节可用该值切换不同路线的剧情映射。",
      "llmRead": true,
      "llmWrite": true
    },
    "story.progress": {
      "type": "string",
      "default": "FreePlot1",
      "description": "当前章节内的剧情节点，由 timeline resolver 写入，供调试和后续章节切换使用。",
      "llmRead": true,
      "llmWrite": false
    },
    "story.location": {
      "type": "enum",
      "values": ["school", "classroom", "third_music_room"],
      "default": "school",
      "description": "最近一段剧情发生地点的标准化 key，由 after_response 场景解析写入。",
      "llmRead": true,
      "llmWrite": false
    },
    "story.locationText": {
      "type": "string",
      "default": "峰城大附属中学",
      "description": "最近一段剧情回复中写出的原始地点文本。",
      "llmRead": true,
      "llmWrite": false
    },
    "visual.textPanel": {
      "type": "enum",
      "values": ["center", "left", "right"],
      "default": "right",
      "description": "剧情阅读面板位置",
      "llmRead": false,
      "llmWrite": false
    }
  }
}
