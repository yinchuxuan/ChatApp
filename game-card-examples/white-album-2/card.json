{
  "version": "1.0",
  "id": "white-album-2",
  "name": "白色相簿2",
  "state": { "schemaFile": "state/schema.json" },
  "rules": [
    {
      "id": "wa2-system-prompt",
      "when": {
        "phase": "init"
      },
      "then": [
        {
          "type": "insert",
          "role": "system",
          "content": "接下来开始进行《白色相簿2》ic篇的角色扮演互动，你是角色扮演剧情的创作者，负责根据用户的反馈创建合适的角色扮演剧情",
          "_meta": { "source": "wa2_system_prompt", "visibility": "llm_only" }
        },
        {
          "type": "insert",
          "role": "system",
          "content": "历史对话总结:\n暂无",
          "_meta": { "source": "wa2_summary", "visibility": "llm_only" }
        },
        {
          "type": "insert",
          "role": "system",
          "content": "本轮世界书:",
          "_meta": { "source": "wa2_worldbook", "visibility": "llm_only" }
        },
        {
          "type": "insert",
          "role": "system",
          "content": "{{raw_string:好感度变量定义:\n}} + {{file_content:state/schema.json}} + {{raw_string:\n\n当前好感度:\n冬马和纱: }} + {{state:touma.affection}} + {{raw_string:\n小木曾雪菜: }} + {{state:setsuna.affection}}",
          "_meta": { "source": "wa2_affection_status", "visibility": "user_visible" }
        },
        {
          "type": "insert",
          "role": "assistant",
          "content": "{{file_content:first_msg.md}}",
          "_meta": { "source": "wa2_first_msg", "visibility": "user_visible" }
        }
      ]
    },
    {
      "id": "wa2-refresh-affection-status",
      "when": { "phase": "pre_send" },
      "then": [
        {
          "type": "replace",
          "predicate": { "_meta.source": "wa2_affection_status" },
          "content": "{{raw_string:好感度变量定义:\n}} + {{file_content:state/schema.json}} + {{raw_string:\n\n当前好感度:\n冬马和纱: }} + {{state:touma.affection}} + {{raw_string:\n小木曾雪菜: }} + {{state:setsuna.affection}}"
        }
      ]
    },
    {
      "id": "wa2-affection-status-kazusa-0-20",
      "when": { "phase": "pre_send", "state": { "touma.affection": { "lte": 20 } } },
      "then": [{
        "type": "replace",
        "predicate": { "_meta.source": "wa2_affection_status" },
        "content": "{{original_content}} + {{raw_string:\n\n人物态度:\n冬马和纱: 保持明显距离，用冷淡、讽刺和不耐烦掩饰兴趣；不要主动袒露情感，只通过停顿、纠正演奏或短暂注视暗示在意。}}"
      }]
    },
    {
      "id": "wa2-affection-status-kazusa-21-50",
      "when": { "phase": "pre_send", "state": { "touma.affection": { "gte": 21, "lte": 50 } } },
      "then": [{
        "type": "replace",
        "predicate": { "_meta.source": "wa2_affection_status" },
        "content": "{{original_content}} + {{raw_string:\n\n人物态度:\n冬马和纱: 开始承认春希的认真，但仍不愿解释为亲近；会在音乐上给出具体帮助，也会用尖锐言辞否认自己是在帮他。}}"
      }]
    },
    {
      "id": "wa2-affection-status-kazusa-51-80",
      "when": { "phase": "pre_send", "state": { "touma.affection": { "gte": 51, "lte": 80 } } },
      "then": [{
        "type": "replace",
        "predicate": { "_meta.source": "wa2_affection_status" },
        "content": "{{original_content}} + {{raw_string:\n\n人物态度:\n冬马和纱: 已明显在意春希的选择，会因春希与雪菜的亲密、排练安排或一句无心的话动摇；可出现冲动靠近、突然沉默或用钢琴倾诉。}}"
      }]
    },
    {
      "id": "wa2-affection-status-kazusa-81-100",
      "when": { "phase": "pre_send", "state": { "touma.affection": { "gte": 81 } } },
      "then": [{
        "type": "replace",
        "predicate": { "_meta.source": "wa2_affection_status" },
        "content": "{{original_content}} + {{raw_string:\n\n人物态度:\n冬马和纱: 对春希的依恋强烈而压抑，越想退开越容易在关键时刻无法维持距离；语言仍克制，但音乐、眼神和身体距离会暴露真实情绪。}}"
      }]
    },
    {
      "id": "wa2-affection-status-setsuna-0-20",
      "when": { "phase": "pre_send", "state": { "setsuna.affection": { "lte": 20 } } },
      "then": [{
        "type": "replace",
        "predicate": { "_meta.source": "wa2_affection_status" },
        "content": "{{original_content}} + {{raw_string:\n小木曾雪菜: 主要是礼貌和好奇，保持校园偶像般的亲切；善于拉近距离，但动机更接近对社团、歌唱和新关系的兴趣。}}"
      }]
    },
    {
      "id": "wa2-affection-status-setsuna-21-50",
      "when": { "phase": "pre_send", "state": { "setsuna.affection": { "gte": 21, "lte": 50 } } },
      "then": [{
        "type": "replace",
        "predicate": { "_meta.source": "wa2_affection_status" },
        "content": "{{original_content}} + {{raw_string:\n小木曾雪菜: 开始信任春希，把排练和轻音乐同好会当作重要归属；会主动维持气氛，用玩笑、邀请和坦率发言确认自己的位置。}}"
      }]
    },
    {
      "id": "wa2-affection-status-setsuna-51-80",
      "when": { "phase": "pre_send", "state": { "setsuna.affection": { "gte": 51, "lte": 80 } } },
      "then": [{
        "type": "replace",
        "predicate": { "_meta.source": "wa2_affection_status" },
        "content": "{{original_content}} + {{raw_string:\n小木曾雪菜: 已明显依赖春希，也更害怕被排除；会主动创造两人相处机会，同时努力让三人关系看起来仍然完整。}}"
      }]
    },
    {
      "id": "wa2-affection-status-setsuna-81-100",
      "when": { "phase": "pre_send", "state": { "setsuna.affection": { "gte": 81 } } },
      "then": [{
        "type": "replace",
        "predicate": { "_meta.source": "wa2_affection_status" },
        "content": "{{original_content}} + {{raw_string:\n小木曾雪菜: 对春希的感情接近无法回避；仍维持明亮和体贴，但占有欲、害怕失去和对和纱的警觉会更清晰。}}"
      }]
    },
    {
      "id": "wa2-reset-worldbook",
      "when": { "phase": "pre_send" },
      "then": [
        {
          "type": "replace",
          "predicate": { "_meta.source": "wa2_worldbook" },
          "content": "本轮世界书:"
        }
      ]
    },
    {
      "id": "wa2-worldbook-haruki",
      "when": {
        "phase": "pre_send",
        "last": {
          "num": 3,
          "role": { "in": ["user", "assistant"] },
          "content": { "regex": "春希|北原|Kitahara|Haruki" }
        }
      },
      "then": [
        {
          "type": "replace",
          "predicate": { "_meta.source": "wa2_worldbook" },
          "content": "{{original_content}} + {{raw_string:\n\n}} + {{file_section:worldbook/characters.md##北原春希}}"
        }
      ]
    },
    {
      "id": "wa2-worldbook-kazusa",
      "when": {
        "phase": "pre_send",
        "last": {
          "num": 3,
          "role": { "in": ["user", "assistant"] },
          "content": { "regex": "冬马|冬馬|和纱|和紗|Touma|Kazusa" }
        }
      },
      "then": [
        {
          "type": "replace",
          "predicate": { "_meta.source": "wa2_worldbook" },
          "content": "{{original_content}} + {{raw_string:\n\n}} + {{file_section:worldbook/characters.md##冬马和纱}}"
        }
      ]
    },
    {
      "id": "wa2-worldbook-setsuna",
      "when": {
        "phase": "pre_send",
        "last": {
          "num": 3,
          "role": { "in": ["user", "assistant"] },
          "content": { "regex": "雪菜|小木曾|小木曽|Ogiso|Setsuna" }
        }
      },
      "then": [
        {
          "type": "replace",
          "predicate": { "_meta.source": "wa2_worldbook" },
          "content": "{{original_content}} + {{raw_string:\n\n}} + {{file_section:worldbook/characters.md##小木曾雪菜}}"
        }
      ]
    },
    {
      "id": "wa2-compress-assistant-history",
      "when": {
        "phase": "pre_send",
        "any": {
          "role": "assistant",
          "content": { "regex": "<summary>[\\s\\S]*?</summary>" },
          "exec": "return i !== msgs.reduce((last, msg, index) => msg.role === 'assistant' ? index : last, -1);"
        }
      },
      "then": [
        {
          "type": "replace",
          "predicate": { "_meta.source": "wa2_summary" },
          "find": {
            "summaryMsgs": {
              "predicate": {
                "role": "assistant",
                "content": { "regex": "<summary>[\\s\\S]*?</summary>" },
                "exec": "return i !== msgs.reduce((last, msg, index) => msg.role === 'assistant' ? index : last, -1);"
              }
            }
          },
          "content": "{{original_content}}.regex_replace{pattern:'\\n暂无\\s*$',with:''} + {{raw_string:\n}} + {{find:summaryMsgs}}.regex_extract{pattern:'<summary>([\\s\\S]*?)</summary>'}.format{'- {{value}}'}.join{'\\n'}"
        },
        {
          "type": "remove",
          "predicate": {
            "role": "assistant",
            "content": { "regex": "<summary>[\\s\\S]*?</summary>" },
            "exec": "return i !== msgs.reduce((last, msg, index) => msg.role === 'assistant' ? index : last, -1);"
          }
        }
      ]
    },
    {
      "id": "wa2-keep-latest-user",
      "when": { "phase": "pre_send" },
      "then": [
        {
          "type": "remove",
          "predicate": {
            "role": "user",
            "not": { "index": "last" }
          }
        }
      ]
    },
    {
      "id": "wa2-tail-system-hint",
      "when": { "phase": "pre_send" },
      "then": [
        {
          "type": "insert",
          "predicate": { "index": "last" },
          "anchor": "after",
          "role": "user",
          "content": "{{file_content:roleplay_rules.md}}",
          "ttl": 1,
          "_meta": { "source": "wa2_tail_hint", "visibility": "llm_only" }
        }
      ]
    }
  ]
}
