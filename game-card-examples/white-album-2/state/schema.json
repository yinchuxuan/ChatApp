{
  "schema": {
    "touma.affection": {
      "type": "number",
      "default": 0,
      "min": 0,
      "max": 100,
      "onInvalid": "clamp",
      "description": "冬马和纱对玩家/春希当前路线的好感度",
      "llmRead": true,
      "uiVisible": true
    },
    "setsuna.affection": {
      "type": "number",
      "default": 0,
      "min": 0,
      "max": 100,
      "onInvalid": "clamp",
      "description": "小木曾雪菜对玩家/春希当前路线的好感度",
      "llmRead": true,
      "uiVisible": true
    },
    "timeline.currentTime": {
      "type": "string",
      "default": "2007.10.21: 08:00 星期日",
      "description": "当前剧情具体时间点，格式固定为 YYYY.MM.DD: HH:mm 星期X。LLM 每轮用 state.set 写入本轮正文结束时的时间，剧情引导按该时间落入的区间选择。",
      "llmRead": true,
      "llmWrite": true
    },
    "visual.textPanel": {
      "type": "enum",
      "values": ["center", "left", "right"],
      "default": "right",
      "description": "剧情阅读面板位置",
      "llmRead": false,
      "llmWrite": false
    },
    "status.setsunaContestAccepted": {
      "type": "boolean",
      "default": false,
      "description": "小木曾雪菜是否同意参加峰城大附属小姐竞选",
      "llmRead": true,
      "llmWrite": true
    }
  }
}
