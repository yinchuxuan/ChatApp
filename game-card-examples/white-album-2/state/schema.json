{
  "schema": {
    "touma.affection": {
      "type": "number",
      "default": 0,
      "min": 0,
      "max": 100,
      "onInvalid": "clamp",
      "description": "冬马和纱对玩家/春希当前路线的好感度",
      "llmRead": true,
      "uiVisible": true
    },
    "setsuna.affection": {
      "type": "number",
      "default": 0,
      "min": 0,
      "max": 100,
      "onInvalid": "clamp",
      "description": "小木曾雪菜对玩家/春希当前路线的好感度",
      "llmRead": true,
      "uiVisible": true
    },
    "timeline.currentTime": {
      "type": "string",
      "default": "2007.10.21: 08:00 星期日",
      "description": "当前剧情具体时间点，格式固定为 YYYY.MM.DD: HH:mm 星期X。LLM 每轮用 state.set 写入本轮正文结束时的时间，剧情引导按该时间落入的区间选择。",
      "llmRead": true,
      "llmWrite": true
    },
    "story.chapter": {
      "type": "enum",
      "values": ["chapter_1"],
      "default": "chapter_1",
      "description": "当前剧情章节。章节 timeline resolver 根据该值选择对应章节的剧情映射。",
      "llmRead": true,
      "llmWrite": true
    },
    "story.route": {
      "type": "enum",
      "values": ["common"],
      "default": "common",
      "description": "当前剧情路线。后续章节可用该值切换不同路线的剧情映射。",
      "llmRead": true,
      "llmWrite": true
    },
    "story.progress": {
      "type": "string",
      "default": "FreePlot1",
      "description": "当前章节内的剧情节点，由 timeline resolver 写入，供调试和后续章节切换使用。",
      "llmRead": true,
      "llmWrite": false
    },
    "visual.textPanel": {
      "type": "enum",
      "values": ["center", "left", "right"],
      "default": "right",
      "description": "剧情阅读面板位置",
      "llmRead": false,
      "llmWrite": false
    }
  }
}
