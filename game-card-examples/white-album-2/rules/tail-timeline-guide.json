[{"id":"wa2-tail-timeline-guide",
  "when":{"phase":"pre_send"},
  "then":[
    {"type":"exec","sourceFile":"scripts/timeline.js"},
    {"type":"replace",
     "predicate":{"role":"user","index":"last"},
     "content":{
        "prefix":"{{original_content}}\n\n---\n<wa2_turn_context>\n请结合以上行动和以下剧情引导生成剧情:\n",
        "include":[
            {"when":{"state":{"temp.includeFreeGuide":true}},"content":"{{file:$temp.plotFile#剧情大纲}}"},
            {"when":{"state":{"temp.PlotType":{"exists":true}}},"content":"{{file:$temp.plotFile#$temp.PlotType}}"},
            {"when":{"state":{"temp.plotKind":"free"}},"content":"{{file:$temp.plotFile#$temp.plotMoodSection}}"},
            {"when":{"state":{"temp.plotKind":"free"}},"content":"{{file:$temp.plotFile#$temp.toumaAttitudeSection}}"},
            {"when":{"state":{"temp.plotKind":"free"}},"content":"{{file:$temp.plotFile#$temp.setsunaAttitudeSection}}"},
            {"when":{"state":{"temp.includeFreeGuide":true}},"content":"{{file:$temp.plotFile#剧情限制}}"}
        ],
        "suffix":"\n\n{{file:roleplay_rules}}\n</wa2_turn_context>"
     }
    }
    ]
}]
