{
  "version": "1.0",
  "id": "white-album-2",
  "name": "白色相簿2",
  "state": {
    "schemaFile": "state/schema.json"
  },
  "audio": {
    "bgm": {
      "daily": "audio/WA2_daily.mp3",
      "happy": "audio/WA2_happy.mp3",
      "normal": "audio/WA2_normal.mp3",
      "sad": "audio/WA2_sad.mp3",
      "tragic": "audio/WA2_tragic.mp3",
      "WA_piano": "audio/WA2_WA_piano.ogg",
      "WA_3": "audio/WA2_WA_3.mp3"
    }
  },
  "display": {
    "stylesheet": "display.css",
    "assistant": [
      {
        "id": "wa2-hide-summary-block",
        "stage": "before_markdown",
        "type": "regex_replace",
        "pattern": "\\n*---\\s*\\n\\s*<summary>[\\s\\S]*?<\\/summary>\\s*\\n\\s*---\\s*",
        "flags": "g",
        "replace": "\n\n"
      },
      {
        "id": "wa2-hide-summary-tag",
        "stage": "before_markdown",
        "type": "regex_replace",
        "pattern": "<summary>[\\s\\S]*?<\\/summary>",
        "flags": "g",
        "replace": ""
      },
      {
        "id": "wa2-hide-state-patch-block",
        "stage": "before_markdown",
        "type": "regex_replace",
        "pattern": "\\n*---\\s*\\n\\s*<state_patch>[\\s\\S]*?<\\/state_patch>\\s*\\n\\s*---\\s*",
        "flags": "g",
        "replace": "\n\n"
      },
      {
        "id": "wa2-hide-state-patch-tag",
        "stage": "before_markdown",
        "type": "regex_replace",
        "pattern": "<state_patch>[\\s\\S]*?<\\/state_patch>",
        "flags": "g",
        "replace": ""
      },
      {
        "id": "wa2-scene-time-place",
        "stage": "before_markdown",
        "type": "regex_replace",
        "pattern": "^【时间地点】\\s*([^\\n｜|]+?)\\s*[｜|]\\s*([^\\n]+)$",
        "flags": "gm",
        "replace": "<div class=\"wa2-scene-meta\"><span class=\"wa2-scene-time\">$1</span><span class=\"wa2-scene-place\">$2</span></div>"
      },
      {
        "id": "wa2-choice-card",
        "stage": "before_markdown",
        "type": "regex_replace",
        "pattern": "^([A-D])\\.\\s+(.+)$",
        "flags": "gm",
        "replace": "<div class=\"wa2-choice\"><span class=\"wa2-choice-label\">$1</span><span class=\"wa2-choice-text\">$2</span></div>"
      }
    ],
    "user": [
      {
        "id": "wa2-hide-user-turn-context",
        "stage": "before_markdown",
        "type": "regex_replace",
        "pattern": "\\n*---\\s*\\n\\s*<wa2_turn_context>[\\s\\S]*?<\\/wa2_turn_context>\\s*$",
        "flags": "g",
        "replace": ""
      },
      {
        "id": "wa2-hide-user-turn-context-tag",
        "stage": "before_markdown",
        "type": "regex_replace",
        "pattern": "<wa2_turn_context>[\\s\\S]*?<\\/wa2_turn_context>",
        "flags": "g",
        "replace": ""
      }
    ]
  },
  "rules": [
    {
      "$import": "rules/system-prompt.json"
    },
    {
      "$import": "rules/compress-assistant-history.json"
    },
    {
      "$import": "rules/keep-latest-user.json"
    },
    {
      "$import": "rules/insert-turn-context.json"
    },
    {
      "$import": "rules/tail-timeline-guide.json"
    }
  ]
}
