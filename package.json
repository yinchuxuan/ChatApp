{
  "name": "harness_lab",
  "version": "1.0.0",
  "description": "Electron knowledge base application",
  "main": "main.js",
  "scripts": {
    "build": "node build.js",
    "dev": "electron .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pretest": "npm run build",
    "test": "jest --forceExit && npm run test:integration && npm run test:e2e",
    "test:coverage": "jest --coverage --forceExit",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "playwright test --config playwright.config.js",
    "test:e2e-real-api": "set -a; [ ! -f .env ] || . ./.env; set +a; playwright test --config playwright.real-api.config.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "dompurify": "^3.4.2",
    "marked": "^18.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "babel-jest": "^29.0.0",
    "babel-loader": "^9.1.3",
    "electron": "^28.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1"
  }
}
