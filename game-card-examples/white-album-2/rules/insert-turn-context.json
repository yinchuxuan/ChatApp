[{"id":"wa2-insert-turn-context",
  "when":{"phase":"pre_send","any":{"role":"user"}},
  "then":[
        {"type":"insert",
            "predicate":{"role":"user","index":"last"},
            "anchor":"before",
            "role":"system",
            "content":{
                "prefix":"{{file:worldbook.index}}\n",
                "include":[
                    {"content":"{{file:worldbook.characters#北原春希}}"},
                    {"content":"{{file:worldbook.characters#冬马和纱}}"},
                    {"content":"{{file:worldbook.characters#小木曾雪菜}}"},
                    {"when":{"last":{"num":3,"role":{"in":["user","assistant"]},"content":{"regex":"武也|饭冢|飯塚|Takeya|Iizuka"}}},
	                    "content":"{{file:worldbook.characters#饭冢武也}}"},
                    {"when":{"last":{"num":3,"role":{"in":["user","assistant"]},"content":{"regex":"依绪|依緒|水泽|水沢|Io|Mizusawa"}}},
	                    "content":"{{file:worldbook.characters#水泽依绪}}"},
                    {"when":{"last":{"num":3,"role":{"in":["user","assistant"]},"content":{"regex":"柳原朋|柳原|Yanagihara|Tomo"}}},
	                    "content":"{{file:worldbook.characters#柳原朋}}"},
                    {"when":{"last":{"num":3,"role":{"in":["user","assistant"]},"content":{"regex":"第二音乐教室|第二音乐室｜第二音楽室"}}},
	                    "content":"{{file:worldbook.location#第二音乐教室}}"},
                    {"when":{"last":{"num":3,"role":{"in":["user","assistant"]},"content":{"regex":"第三音乐教室|第三音乐室|第三音楽室"}}},
	                    "content":"{{file:worldbook.location#第三音乐教室}}"},
                    {"when":{"last":{"num":3,"role":{"in":["user","assistant"]},"content":{"regex":"峰城大附属中学|峰城大附属|峰城大付属"}}},
	                    "content":"{{file:worldbook.location#峰城大附属中学}}"},
                    {"when":{"last":{"num":3,"role":{"in":["user","assistant"]},"content":{"regex":"冬马家|冬馬家|和纱家|和紗家"}}},
	                    "content":"{{file:worldbook.location#冬马家}}"}
                ],
                "join":"\n\n",
                "default":"无"
            },
            "ttl":1,
            "_meta":{"source":"wa2_worldbook","visibility":"llm_only"}
        },
        {"type":"insert",
         "predicate":{"role":"user","index":"last"},
         "anchor":"before",
         "role":"system",
	         "content":"State定义:\n{{file:state.llm_schema}}\n\n当前State:\n- timeline.currentTime: {{state:timeline.currentTime}}\n- timeline.currentSlot: {{state:timeline.currentSlot}}\n- timeline.currentSlotEnd: {{state:timeline.currentSlotEnd}}\n- touma.affection: {{state:touma.affection}}\n- setsuna.affection: {{state:setsuna.affection}}\n- performance.proficiency: {{state:performance.proficiency}}\n\n{{file:state.update_rules}}",
         "ttl":1,
         "_meta":{"source":"wa2_state_context",
         "visibility":"llm_only"}
        }
        ]
    }
]
