[{"id":"wa2-tail-timeline-guide",
  "when":{"phase":"pre_send"},
  "then":[
    {"type":"state.set","path":"temp.PlotType","value":"FreePlot1",
     "when":{"state":{"timeline.currentTime":{"lte":"2007.10.21: 10:00 星期日"}}}},
    {"type":"state.set","path":"temp.PlotType","value":"FixedPlot1",
     "when":{"state":{"timeline.currentTime":{"gt":"2007.10.21: 10:00 星期日","lte":"2007.10.21: 16:00 星期日"}}}},
    {"type":"state.set","path":"temp.PlotType","value":"FreePlot2",
     "when":{"state":{"timeline.currentTime":{"gt":"2007.10.21: 16:00 星期日","lte":"2007.10.22: 20:00 星期一"}}}},
    {"type":"state.set","path":"temp.PlotType","value":"FixedPlot2",
     "when":{"state":{"timeline.currentTime":{"gt":"2007.10.22: 20:00 星期一","lte":"2007.10.23: 10:00 星期二"}}}},
    {"type":"state.set","path":"temp.PlotType","value":"FreePlot3",
     "when":{"state":{"timeline.currentTime":{"gt":"2007.10.23: 10:00 星期二","lte":"2007.10.24: 20:00 星期三"}}}},
    {"type":"state.set","path":"temp.PlotType","value":"FixedPlot3",
     "when":{"state":{"timeline.currentTime":{"gt":"2007.10.24: 20:00 星期三","lte":"2007.10.25: 10:00 星期四"}}}},
    {"type":"state.set","path":"temp.PlotType","value":"FixedPlot4",
     "when":{"state":{"timeline.currentTime":{"gt":"2007.10.25: 10:00 星期四","lte":"2007.10.25: 16:00 星期四"}}}},
    {"type":"state.randomInt","path":"temp.plotDirectionRoll","min":1,"max":100,
     "when":{"state":{"temp.PlotType":{"regex":"^FreePlot"}}}},
    {"type":"state.set","path":"audio.bgm","value":"tragic",
     "when":{"state":{"temp.PlotType":{"regex": "^FreePlot"},"temp.plotDirectionRoll":{"lte":10}}}},
    {"type":"state.set","path":"audio.bgm","value":"sad",
     "when":{"state":{"temp.PlotType":{"regex": "^FreePlot"},"temp.plotDirectionRoll":{"gt":10,"lt":30}}}},
    {"type":"state.set","path":"audio.bgm","value":"normal",
     "when":{"state":{"temp.PlotType":{"regex": "^FreePlot"},"temp.plotDirectionRoll":{"gte":30,"lt":70}}}},
    {"type":"state.set","path":"audio.bgm","value":"daily",
     "when":{"state":{"temp.PlotType":{"regex": "^FreePlot"},"temp.plotDirectionRoll":{"gte":70,"lt":90}}}},
    {"type":"state.set","path":"audio.bgm","value":"happy",
     "when":{"state":{"temp.PlotType":{"regex": "^FreePlot"},"temp.plotDirectionRoll":{"gte":90}}}},
    {"type":"state.set","path":"audio.bgm","value":"WA_piano","when":{"state":{"temp.PlotType":{"eq":"FixedPlot1"}}}},
    {"type":"state.set","path":"audio.bgm","value":"normal","when":{"state":{"temp.PlotType":{"eq":"FixedPlot2"}}}},
    {"type":"state.set","path":"audio.bgm","value":"sad","when":{"state":{"temp.PlotType":{"eq":"FixedPlot3"}}}},
    {"type":"state.set","path":"audio.bgm","value":"WA_3","when":{"state":{"temp.PlotType":{"eq":"FixedPlot4"}}}},
    {"type":"state.set","path":"visual.background","value":"school","when":{"state":{"temp.PlotType":{"regex": "^FreePlot"}}}},
    {"type":"state.set","path":"visual.background","value":"musical_classroom3","when":{"state":{"temp.PlotType":{"eq":"FixedPlot1"}}}},
    {"type":"state.set","path":"visual.background","value":"invite","when":{"state":{"temp.PlotType":{"eq":"FixedPlot2"}}}},
    {"type":"state.set","path":"visual.background","value":"haiku","when":{"state":{"temp.PlotType":{"eq":"FixedPlot3"}}}},
    {"type":"state.set","path":"visual.background","value":"rooftop","when":{"state":{"temp.PlotType":{"eq":"FixedPlot4"}}}},
    {"type":"replace",
     "predicate":{"role":"user","index":"last"},
     "content":{
        "prefix":"{{original_content}} + {{raw_string:\n\n---\n<wa2_turn_context>\n请结合以上行动和以下剧情引导生成剧情:\n}}",
        "include":[
            {"when":{"state":{"temp.PlotType":{"eq":"FixedPlot1"}}}, "content":"{{file_section:plot_guides.md##FixedPlot1}}"},
            {"when":{"state":{"temp.PlotType":{"eq":"FixedPlot2"}}}, "content":"{{file_section:plot_guides.md##FixedPlot2}}"},
            {"when":{"state":{"temp.PlotType":{"eq":"FixedPlot3"}}}, "content":"{{file_section:plot_guides.md##FixedPlot3}}"},
            {"when":{"state":{"temp.PlotType":{"eq":"FixedPlot4"}}}, "content":"{{file_section:plot_guides.md##FixedPlot4}}"},
            {"when":{"state":{"temp.PlotType":{"eq":"FreePlot1"}}}, "content":"{{file_section:plot_guides.md##FreePlot1}}"},
            {"when":{"state":{"temp.PlotType":{"eq":"FreePlot2"}}}, "content":"{{file_section:plot_guides.md##FreePlot2}}"},
            {"when":{"state":{"temp.PlotType":{"eq":"FreePlot3"}}}, "content":"{{file_section:plot_guides.md##FreePlot3}}"},
            {"when":{"state":{"temp.PlotType":{"regex":"^FreePlot"},"audio.bgm":{"eq":"tragic"}}}, "content":"本轮剧情走向: 极度负面。让关系出现强烈刺痛、误解或逃避，场面压抑到接近失控，但不要破坏固定主线。"}, 
            {"when":{"state":{"temp.PlotType":{"regex":"^FreePlot"},"audio.bgm":{"eq":"sad"}}}, "content":"本轮剧情走向: 负面。让误会、执行委员压力或角色逃避使局面变重，但保留后续缓和空间。"},
            {"when":{"state":{"temp.PlotType":{"regex":"^FreePlot"},"audio.bgm":{"eq":"normal"}}}, "content":"本轮剧情走向: 日常。顺着用户选择写音乐练习、校园事务、微妙视线和克制对话，让关系变化来自性格与前文因果。"},
            {"when":{"state":{"temp.PlotType":{"regex":"^FreePlot"},"audio.bgm":{"eq":"daily"}}}, "content":"本轮剧情走向: 正面。让排练更顺利、某个角色放下少许戒备，或让一次小小体贴被认真记住"},
            {"when":{"state":{"temp.PlotType":{"regex":"^FreePlot"},"audio.bgm":{"eq":"happy"}}}, "content":"本轮自由剧情走向: 极度正面。让一次难得的默契、主动靠近或被认真理解的瞬间明显推进关系，但仍保持白色相簿2式克制。"},
            {"when":{"state":{"temp.PlotType":{"regex":"^FreePlot"},"touma.affection":{"lt":10}}},"content":"冬马和纱当前态度: 保持明显距离，用冷淡、讽刺和不耐烦掩饰兴趣；只通过偷偷注视暗示在意。"},
            {"when":{"state":{"temp.PlotType":{"regex":"^FreePlot"},"touma.affection":{"gte":10}}},"content":"冬马和纱当前态度: 开始承认春希的认真，但仍不愿解释为亲近；会在音乐上给出具体帮助，也会用尖锐言辞否认自己是在帮他。"},
            {"when":{"state":{"temp.PlotType":{"regex":"^FreePlot"},"setsuna.affection":{"lt":10}}},"content":"小木曾雪菜当前态度: 较为陌生, 保持校园偶像对待同学的完美表现；表面友好实则内心隔着一层距离。"},
            {"when":{"state":{"temp.PlotType":{"regex":"^FreePlot"},"setsuna.affection":{"gte":10}}},"content":"小木曾雪菜当前态度: 开始信任春希，向春希袒露自己校园偶像外表下普通女孩的真实；会主动维持气氛，用邀请和坦率发言确认自己的位置。"},
            {"when":{"state":{"temp.PlotType":{"regex":"^FreePlot"},"temp.plotDirectionRoll":{"gt":0}}},"content":"{{file_section:plot_guides.md##剧情限制}}"}
        ],
        "suffix":"{{raw_string:\n\n}} + {{file_content:roleplay_rules.md}} + {{raw_string:\n</wa2_turn_context>}}"
     }
    }
    ]
}]
